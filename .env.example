# API base URL (Express backend)
# Local dev — Vite proxies /api → localhost:3000 (see vite.config.js):
VITE_API_BASE_URL=/api

# Production on Vercel — use /api (frontend vercel.json proxies to the backend).
# Direct backend URL also works if you skip the proxy:
# VITE_API_BASE_URL=https://your-backend.vercel.app/api

# Supabase (optional — for direct client access in future phases)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
